---
import UseTablerIcon from "./UseTablerIcon.astro";
---

<nav class="sticky top-0 h-18 bg-white border-b border-b-neutral-100 z-50">
  <div class="container px-6 sm:px-0 h-18 flex items-center justify-between">
    <h1 class="font-bold">Easy Icons</h1>
    <div class="flex items-center gap-x-4">
      <a
        href="https://github.com/farhanfadila1717/easy-icons"
        class="flex items-center gap-x-2 px-4 py-1 border border-neutral-200 rounded-full"
      >
        <UseTablerIcon unicode={59816} />
        <p class="text-sm">Github</p>
      </a>
      <a
        href="https://pub.dev/packages/easy_icons"
        class="flex items-center gap-x-2 px-4 py-1 border border-neutral-200 rounded-full"
      >
        <UseTablerIcon unicode={60329} />
        <p class="text-sm">Pub.dev</p>
      </a>
    </div>
  </div>
</nav>
